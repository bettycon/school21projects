		{
			"name": "Новости по Разработке на русском (15 дней)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const today = new Date();\r",
							"const fromDate = new Date();\r",
							"fromDate.setDate(today.getDate() - 15);\r",
							"\r",
							"pm.collectionVariables.set(\"fromDate\", fromDate.toISOString().split('T')[0]);\r",
							"pm.collectionVariables.set(\"toDate\", today.toISOString().split('T')[0]);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
